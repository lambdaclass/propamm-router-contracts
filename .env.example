# Copy to .env and fill in. Foundry auto-loads .env for `vm.env*` reads in
# scripts. For the CLI flags below (RPC_URL, *_KEY), also `source .env` so they
# expand in your shell.
#
# NOTE: the execution delays (UPGRADE_DELAY 7d, RESUME_DELAY 1h, ADMIN_DELAY 7d)
# are codified as constants in RouterAccessManager — they are NOT env vars.

# ──────────────────────────────────────────────────────────────────────────
# Common (passed as forge --rpc-url / --private-key flags)
# ──────────────────────────────────────────────────────────────────────────
RPC_URL=https://ethereum-rpc.publicnode.com
# Deployer key for Deploy.s.sol; MUST correspond to ROUTER_ADMIN.
DEPLOYER_KEY=0x...
# Key holding UPGRADER_ROLE, for Upgrade.s.sol and Execute.s.sol.
UPGRADER_KEY=0x...

# ──────────────────────────────────────────────────────────────────────────
# Deploy.s.sol
# ──────────────────────────────────────────────────────────────────────────
# Required. Bootstrap admin of the manager; MUST be the broadcasting account
# (configureRouter + the handoff are admin-gated).
ROUTER_ADMIN=0x...
# Required. Holder of UPGRADER_ROLE (upgrades + fallback config + rescueTokens).
ROUTER_UPGRADER=0x...
# Required. Holder of GUARDIAN_ROLE (instant pause).
ROUTER_GUARDIAN=0x...

# Optional. Holder of RESUMER_ROLE (unpause, 1h delay). Defaults to ROUTER_UPGRADER.
# Set equal to ROUTER_GUARDIAN to let the guardian also unpause (via the 1h path).
# ROUTER_RESUMER=0x...

# Optional. Governance multisig to receive ADMIN_ROLE. If unset, ROUTER_ADMIN
# stays a delay-0 master key (a warning is logged).
# GOV_ADMIN=0x...
# Optional. Execution delay (seconds) granted to GOV_ADMIN. Default: 604800 (7 days).
# ADMIN_EXEC_DELAY=604800
# Optional. If true, ROUTER_ADMIN renounces ADMIN_ROLE after granting GOV_ADMIN. Default: false.
# RENOUNCE_BOOTSTRAP=false

# ──────────────────────────────────────────────────────────────────────────
# Upgrade.s.sol  (schedules a delayed UUPS upgrade)
# ──────────────────────────────────────────────────────────────────────────
# Required. The RouterAccessManager address (logged by Deploy.s.sol).
ACCESS_MANAGER=0x...
# Required. The router proxy to upgrade (logged by Deploy.s.sol).
ROUTER_PROXY=0x...
# Required. New implementation contract in src/ (e.g. "PropAMMRouterV2.sol").
ROUTER_IMPL_NAME=PropAMMRouterV2.sol
# Optional. Reference contract for storage-layout validation (e.g. "PropAMMRouter.sol"),
# unless the new impl declares its predecessor via an oz-upgrades-from annotation.
# ROUTER_IMPL_REFERENCE=PropAMMRouter.sol

# ──────────────────────────────────────────────────────────────────────────
# Execute.s.sol  (executes any scheduled, now-ready operation)
# ──────────────────────────────────────────────────────────────────────────
# ACCESS_MANAGER is reused from above.
# Required. Target of the scheduled call (the proxy, for an upgrade).
EXEC_TARGET=0x...
# Required. Exact calldata that was scheduled (0x-prefixed hex; logged by Upgrade.s.sol).
EXEC_DATA=0x...
